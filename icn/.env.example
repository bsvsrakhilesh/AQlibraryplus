PORT=
HOST=

# Human-readable node name for logs and backend provenance
ICN_NODE_NAME=

# Must match the backend secret exactly
ICN_SHARED_SECRET=

# Keep false for the first setup so you can complete login in a visible browser window
ICN_HEADLESS=

ICN_NAV_TIMEOUT_MS=
ICN_ACTION_TIMEOUT_MS=

# Persistent browser profile path (stores cookies/session/local storage)
ICN_USER_DATA_DIR=

# Default place to open when you trigger interactive login
ICN_DEFAULT_LOGIN_URL=
ICN_BROWSER_EXECUTABLE_PATH=
ICN_BROWSER_CHANNEL=

# Optional; keep permissive for local dev
ICN_ALLOWED_ORIGIN=